<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- PROJECT TASK LIST VIEW INHERITANCE -->
    <record id="view_task_tree_oversight_inherit" model="ir.ui.view">
        <field name="name">project.task.tree.oversight</field>
        <field name="model">project.task</field>
        <field name="inherit_id" ref="project.view_task_tree2"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='date_deadline']" position="after">
                <field name="oversight_progress" widget="progressbar" string="Oversight Progress"/>
                <field name="oversight_remaining_hours" string="Hrs Left"/>
                <field name="oversight_is_delayed" string="Delayed" widget="boolean_toggle"/>
            </xpath>
        </field>
    </record>

    <!-- PROJECT TASK FORM VIEW INHERITANCE -->
    <record id="view_task_form_oversight_inherit" model="ir.ui.view">
        <field name="name">project.task.form.oversight</field>
        <field name="model">project.task</field>
        <field name="inherit_id" ref="project.view_task_form2"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='allocated_hours']" position="after">
                <field name="oversight_progress" widget="progressbar" invisible="allocated_hours == 0"/>
                <field name="oversight_remaining_hours" invisible="allocated_hours == 0"/>
                <field name="oversight_is_delayed" widget="boolean_toggle" invisible="not oversight_is_delayed"/>
            </xpath>
        </field>
    </record>

    <!-- PROJECT TASK KANBAN VIEW INHERITANCE -->
    <record id="view_task_kanban_oversight_inherit" model="ir.ui.view">
        <field name="name">project.task.kanban.oversight</field>
        <field name="model">project.task</field>
        <field name="inherit_id" ref="project.view_task_kanban"/>
        <field name="arch" type="xml">
            <xpath expr="//kanban" position="inside">
                <field name="oversight_progress"/>
                <field name="oversight_remaining_hours"/>
                <field name="oversight_is_delayed"/>
            </xpath>
            <xpath expr="//div[hasclass('oe_kanban_bottom_right')]" position="before">
                <div class="o_oversight_kanban" style="margin-top: 5px;">
                    <t t-if="record.oversight_is_delayed.raw_value">
                        <span class="badge bg-danger text-white">DELAYED</span>
                    </t>
                    <div class="progress" style="height: 5px;">
                        <div class="progress-bar bg-success" 
                             role="progressbar" 
                             t-attf-style="width: {{ record.oversight_progress.raw_value }}%;" 
                             aria-valuemin="0" 
                             aria-valuemax="100"/>
                    </div>
                </div>
            </xpath>
        </field>
    </record>
</odoo>
