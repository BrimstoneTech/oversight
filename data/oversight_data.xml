<?xml version="1.0" encoding="utf-8"?>
<!-- OVERSIGHT: Automated Actions (Cron Jobs) -->
<!-- Three daily cron jobs:
     1. Recompute all stored oversight fields on analytic lines
     2. Recompute all stored oversight fields on appraisals
     3. Send email/chatter delay alerts for tasks past their deadline
     All jobs run once per day at 06:00 server time. -->
<odoo>

    <!-- ─────────────────────────────────────────────────────────────────
         1. Recompute Timesheet Oversight Fields
         Triggers _compute_task_progress and _compute_efficiency_score
         on all stored compute fields (store=True) that depend on
         timesheet lines. Since fields are stored=True, a simple search
         + ORM write of a trigger value is sufficient. We call the
         compute directly via cron code for reliability.
    ───────────────────────────────────────────────────────────────── -->
    <record id="cron_recompute_timesheet_oversight" model="ir.cron">
        <field name="name">OVERSIGHT: Recompute Timesheet Metrics</field>
        <field name="model_id" ref="analytic.model_account_analytic_line"/>
        <field name="state">code</field>
        <field name="code">
lines = model.search([('project_id', '!=', False)])
lines._compute_oversight_task_progress()
lines._compute_oversight_efficiency_score()
        </field>
        <field name="interval_number">1</field>
        <field name="interval_type">days</field>
        <field name="numbercall">-1</field>
        <field name="active">True</field>
    </record>

    <!-- ─────────────────────────────────────────────────────────────────
         2. Recompute Appraisal Oversight Fields (DISABLED - NO HR_APPRAISAL)
    ───────────────────────────────────────────────────────────────── -->
    <!--
    <record id="cron_recompute_appraisal_oversight" model="ir.cron">
        <field name="name">OVERSIGHT: Recompute Appraisal Performance Metrics</field>
        <field name="model_id" ref="hr_appraisal.model_hr_appraisal"/>
        <field name="state">code</field>
        <field name="code">
appraisals = model.search([('state', 'not in', ['done'])])
appraisals._compute_oversight_timesheet_ids()
appraisals._compute_avg_completion()
appraisals._compute_avg_efficiency()
appraisals._compute_total_hours_logged()
        </field>
        <field name="interval_number">1</field>
        <field name="interval_type">days</field>
        <field name="numbercall">-1</field>
        <field name="active">True</field>
    </record>
    -->

    <!-- ─────────────────────────────────────────────────────────────────
         3. Send Delay Alerts for Overdue Tasks
    ───────────────────────────────────────────────────────────────── -->
    <record id="cron_send_delay_alerts" model="ir.cron">
        <field name="name">OVERSIGHT: Send Task Delay Alert Emails</field>
        <field name="model_id" ref="project.model_project_task"/>
        <field name="state">code</field>
        <field name="code">model.search([])._send_delay_alert()</field>
        <field name="interval_number">1</field>
        <field name="interval_type">days</field>
        <field name="numbercall">-1</field>
        <field name="active">True</field>
    </record>

</odoo>
